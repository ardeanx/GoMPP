## GoMPP Environment Configuration
## Copy this file to .env and fill in the values.
## All variables use the GOMPP_ prefix.

# ── JWT (REQUIRED) ──
GOMPP_JWT_SECRET=          # openssl rand -hex 32
GOMPP_JWT_ACCESSEXPIRY_MIN=60
GOMPP_JWT_REFRESHEXPIRY_DAY=7

# ── Server ──
GOMPP_SERVER_HOST=0.0.0.0
GOMPP_SERVER_PORT=8080
GOMPP_SERVER_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# ── Database (PostgreSQL) ──
GOMPP_DATABASE_HOST=localhost
GOMPP_DATABASE_PORT=5432
GOMPP_DATABASE_USER=gompp
GOMPP_DATABASE_PASSWORD=gompp
GOMPP_DATABASE_NAME=gompp
GOMPP_DATABASE_SSLMODE=disable
GOMPP_DATABASE_MAX_CONNS=25
GOMPP_DATABASE_MIN_CONNS=5
GOMPP_DATABASE_MAX_CONN_LIFETIME_MIN=60
GOMPP_DATABASE_MAX_CONN_IDLE_MIN=30
GOMPP_DATABASE_HEALTH_CHECK_MIN=1

# ── Storage ──
GOMPP_STORAGE_BACKEND=local
GOMPP_STORAGE_BASEPATH=./data/media
GOMPP_STORAGE_S3_BUCKET=
GOMPP_STORAGE_S3_REGION=us-east-1
GOMPP_STORAGE_S3_ENDPOINT=
GOMPP_STORAGE_S3_ACCESS_KEY=
GOMPP_STORAGE_S3_SECRET_KEY=
GOMPP_STORAGE_S3_USE_PATH_STYLE=false
GOMPP_STORAGE_S3_PUBLIC_URL=
GOMPP_STORAGE_S3_PREFIX=

# ── Transcoding ──
GOMPP_TRANSCODE_WORKERS=2
GOMPP_TRANSCODE_FFMPEGPATH=ffmpeg
GOMPP_TRANSCODE_FFPROBEPATH=ffprobe
GOMPP_TRANSCODE_TEMPDIR=./data/temp

# ── Logging ──
GOMPP_LOG_LEVEL=info
GOMPP_LOG_FORMAT=console

# ── Google OAuth ──
GOMPP_GOOGLE_CLIENT_ID=

# ── WebAuthn / Passkey ──
GOMPP_WEBAUTHN_RP_DISPLAY_NAME=GoMPP
GOMPP_WEBAUTHN_RP_ID=localhost
GOMPP_WEBAUTHN_RP_ORIGINS=http://localhost:3000

# ── Rate Limiting (defaults, overridable via Security Settings) ──
GOMPP_RATELIMIT_AUTH_RPM=10
GOMPP_RATELIMIT_GENERAL_RPM=60
