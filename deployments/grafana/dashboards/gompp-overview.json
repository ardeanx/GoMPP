            "id": 1,
            "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
            "title": "Request Rate",
            "type": "stat",
            "targets": [
                {
                    "expr": "sum(rate(gompp_http_requests_total[5m]))",
                    "legendFormat": "req/s"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
