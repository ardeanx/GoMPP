FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /bin/gompp ./server

FROM alpine:3.20

RUN apk --no-cache add ca-certificates tzdata ffmpeg \
    && addgroup -S gompp && adduser -S gompp -G gompp \
    && mkdir -p /data/media /data/temp \
    && chown -R gompp:gompp /data

COPY --from=builder /bin/gompp /bin/gompp

USER gompp

EXPOSE 8080

CMD ["/bin/gompp"]
